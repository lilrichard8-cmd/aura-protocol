# ── AURA Mainstream Frontend env ──────────────────────────────────────────

# Bounty V2 on-chain toggle.
# false (default) → BountyCreatePage uses MockChainContext (local state only)
# true            → BountyCreatePage builds real Solana transactions via the
#                   SDK MarketModule. Requires the wallet to be connected,
#                   and the program must be deployed to the network the
#                   wallet adapter is talking to.
VITE_BOUNTY_REAL_CHAIN=false

# Protocol pool addresses (Bounty V2 audit fix C-3).
# These MUST match STAKING_REWARDS_POOL / GAS_RESERVE_POOL / OPS_TREASURY_POOL
# constants in programs/market/src/lib.rs. While the contract uses the
# system program id as a placeholder, leave these unset and the SDK falls
# back to the same placeholder for type-check / read-only paths.
VITE_STAKING_REWARDS_POOL=
VITE_GAS_RESERVE_POOL=
VITE_OPS_TREASURY_POOL=

# Canonical ORA mint (audit fix C-2). Required before any non-official
# bounty can be created; the SDK refuses unmatched mints client-side.
VITE_ORA_MINT=
