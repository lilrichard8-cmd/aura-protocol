# ── AURA Mainstream Frontend env ──────────────────────────────────────────

# Bounty V2 on-chain toggle.
# false (default) → BountyCreatePage uses MockChainContext (local state only)
# true            → BountyCreatePage builds real Solana transactions via the
#                   SDK MarketModule. Requires the wallet to be connected,
#                   and the program must be deployed to the network the
#                   wallet adapter is talking to.
VITE_BOUNTY_REAL_CHAIN=false

# Protocol pool addresses (Bounty V2 audit fix C-3).
# These MUST match STAKING_REWARDS_POOL / GAS_RESERVE_POOL / OPS_TREASURY_POOL
# constants in programs/market/src/lib.rs. While the contract uses the
# system program id as a placeholder, leave these unset and the SDK falls
# back to the same placeholder for type-check / read-only paths.
VITE_STAKING_REWARDS_POOL=
VITE_GAS_RESERVE_POOL=
VITE_OPS_TREASURY_POOL=

# Canonical ORA mint (audit fix C-2). Required before any non-official
# bounty can be created; the SDK refuses unmatched mints client-side.
# Also required for VITE_ORA_REAL_CHAIN (see below) — if unset, the Wallet
# page silently keeps using MockChainContext.
VITE_ORA_MINT=

# ORA wallet on-chain toggle.
# false (default) → WalletPage uses MockChainContext for balance + Send.
# true            → WalletPage reads the live SPL balance from the ORA
#                   mint (VITE_ORA_MINT) and Send executes a real SPL
#                   `createTransferInstruction` against the connected
#                   wallet. Requires VITE_ORA_MINT to be a valid pubkey
#                   and the wallet adapter to be connected. Falls back
#                   transparently to mock if either is missing.
VITE_ORA_REAL_CHAIN=false

# Optional override for the deployed `aura_ora` program id. Defaults to
# the value declared in programs/ora/src/lib.rs. Only needed if you
# redeploy with a different keypair.
VITE_ORA_PROGRAM_ID=

# Creator Coin on-chain toggle.
# false (default) → CoinDetailPage / MintCeremony use MockChainContext
# true            → real Solana transactions via CreatorCoinModule
#                   (primary_buy / create_sell_order / fill_order /
#                    cancel_order / create_creator_coin).
# Reuses VITE_STAKING_REWARDS_POOL / VITE_GAS_RESERVE_POOL /
# VITE_OPS_TREASURY_POOL / VITE_ORA_MINT above.
VITE_CREATOR_COIN_REAL_CHAIN=false

# Core publish + NFT royalty on-chain toggle.
# false (default) → CreatePage publishes through MockChainContext (local
#                   feed only). Royalty slider value is captured but no
#                   set_royalty tx is sent.
# true            → CreatePage calls SDK CoreModule.publishContent for
#                   real, plus MarketModule.setRoyalty when the user
#                   toggles "Mint as NFT". Requires a connected wallet,
#                   the aura_core program deployed at the SDK's
#                   CORE_PROGRAM_ID, and the same protocol pools / ORA
#                   mint env vars listed above (the royalty hook reuses
#                   the Market config).
#
# Until the Arweave uploader is integrated, the on-chain publish path
# passes a deterministic 43-char placeholder for `arweave_tx_id`. The
# core program only validates length, so this works for testing.
VITE_CORE_REAL_CHAIN=false

# Staking on-chain toggle (Tier 1.5).
# false (default) → WalletPage staking tab uses MockChainContext.
# true            → stake / unstake / claim build real Solana txs via
#                   SDK StakingModule. Requires VITE_ORA_MINT to be set
#                   AND the aura_staking program deployed with its pool
#                   initialized (run scripts/init-staking-pool.mjs once).
VITE_STAKING_REAL_CHAIN=false

# Curation on-chain toggle (Tier 1.5).
# false (default) → CurateModal hits MockChainContext.curateContent.
# true            → CurateModal sends a real curate tx via SDK CurationModule
#                   when the post id is an on-chain PostV2 PDA. Posts with
#                   mock-only ids transparently fall back to mock. Requires
#                   VITE_ORA_MINT to be set and each content's curation pool
#                   to have been initialized by an admin.
VITE_CURATION_REAL_CHAIN=false

# Optional override for the on-chain curation fee sink (1 ORA per curation
# flows here). Defaults to programs/curation/src/lib.rs CURATION_FEE_SINK.
VITE_CURATION_FEE_SINK=

# Optional explicit overrides for the staking/curation program IDs. Default
# to SDK PROGRAM_IDS.LOCALNET.{staking,curation}.
VITE_STAKING_PROGRAM_ID=
VITE_CURATION_PROGRAM_ID=
